{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "dependsOn": ["^build", "//#docker:dev:up"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["NEXT_PUBLIC_*", "BABYTALK_*"]
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": ["src/*.gen.ts", "src/*.gen.d.ts", "src/*.schema.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "passThroughEnv": ["NEXT_PUBLIC_*", "BABYTALK_*"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "check": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "//#docker:dev:up": {
      "cache": false,
      "env": ["RESEND_API_KEY", "TAMBO_API_KEY", "NEXT_PUBLIC_*", "BABYTALK_*"]
    },
    "//#docker:dev:down": {
      "cache": false
    }
  }
}
