{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "databaseUrl": {
      "type": "string",
      "description": "PostgreSQL connection string"
    },
    "jwtSecret": {
      "default": "dev-secret-change-me",
      "description": "Secret key for signing JWTs",
      "type": "string"
    },
    "port": {
      "default": 4000,
      "description": "HTTP server port",
      "type": "number"
    },
    "smtpFrom": {
      "default": "noreply@babytalk.dev",
      "description": "Sender email address",
      "type": "string"
    },
    "smtpHost": {
      "default": "localhost",
      "description": "SMTP server hostname",
      "type": "string"
    },
    "smtpPass": {
      "default": "",
      "description": "SMTP password (Resend API key for smtp.resend.com)",
      "type": "string"
    },
    "smtpPort": {
      "default": 1025,
      "description": "SMTP server port",
      "type": "number"
    },
    "smtpUser": {
      "default": "",
      "description": "SMTP username ('resend' for smtp.resend.com)",
      "type": "string"
    },
    "webUrl": {
      "default": "http://localhost:3000",
      "description": "Frontend URL for CORS and email links",
      "type": "string"
    }
  },
  "required": [
    "databaseUrl"
  ]
}
