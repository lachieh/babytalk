{
  "name": "babytalk",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "prepare": "lefthook install || true",
    "db:generate": "turbo db:generate --filter=@babytalk/db",
    "db:migrate": "turbo db:migrate --filter=@babytalk/db",
    "db:studio": "pnpm --filter @babytalk/db drizzle-kit studio",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset tag",
    "docker:build": "docker buildx bake -f docker-bake.hcl",
    "docker:up": "docker buildx bake -f docker-bake.hcl --load && docker compose -f docker-compose.test.yml up -d",
    "docker:down": "docker compose -f docker-compose.test.yml down"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "playwright": "1.58.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "ultracite": "7.3.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.32.1",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": "24.13.1",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@10.32.1"
}
