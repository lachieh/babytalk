{
  "name": "@babytalk/standard-config",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "standard-config": "./dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./vite": {
      "types": "./dist/plugin/vite.d.ts",
      "import": "./dist/plugin/vite.js",
      "default": "./src/plugin/vite.ts"
    },
    "./webpack": {
      "types": "./dist/plugin/webpack.d.ts",
      "import": "./dist/plugin/webpack.js",
      "default": "./src/plugin/webpack.ts"
    },
    "./rollup": {
      "types": "./dist/plugin/rollup.d.ts",
      "import": "./dist/plugin/rollup.js",
      "default": "./src/plugin/rollup.ts"
    },
    "./esbuild": {
      "types": "./dist/plugin/esbuild.d.ts",
      "import": "./dist/plugin/esbuild.js",
      "default": "./src/plugin/esbuild.ts"
    },
    "./loader": {
      "types": "./dist/plugin/webpack-loader.d.ts",
      "import": "./dist/plugin/webpack-loader.js",
      "default": "./src/plugin/webpack-loader.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./src/client.ts"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "default": "./src/next.ts"
    },
    "./well-known/next": {
      "types": "./dist/well-known/next.d.ts",
      "import": "./dist/well-known/next.js",
      "default": "./src/well-known/next.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "defu": "^6.1.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@babytalk/tsconfig": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "@types/node": "^25.5.0",
    "jiti": "^2.6.1",
    "next": "^16.2.3",
    "typescript": "^5.9.3",
    "unplugin": "^3.0.0",
    "valibot": "^1.3.1",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
