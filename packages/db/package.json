{
  "name": "@babytalk/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-beta.18-5ffac6d",
    "postgres": "^3"
  },
  "devDependencies": {
    "@babytalk/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "drizzle-kit": "1.0.0-beta.18-5ffac6d",
    "typescript": "^5"
  }
}
